# Aethos can run without these values in local demo mode.
# Full setup: docs/SUPABASE_SETUP.md · docs/VERCEL_CONNECT_SUPABASE.md · docs/DEPLOYMENT.md

# --- Supabase app runtime (public only — browser-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Calculation service (server-only) ---
# Recommended production: AETHOS_ALLOW_DEMO_FALLBACK=false
AETHOS_CALCULATION_SERVICE_URL=
AETHOS_ALLOW_DEMO_FALLBACK=true
AETHOS_CALC_PROVIDER=demo
# moshier = built-in (golden CI); files = licensed SE path required
AETHOS_SWISS_EPHEMERIS_MODE=moshier
AETHOS_SWISS_EPHEMERIS_PATH=
# Host path for docker compose volume (licensed ephemeris files)
AETHOS_SWISS_EPHEMERIS_HOST_PATH=./services/calculation/ephe

# --- Vercel Connect → Supabase MCP (ops / agents only; not app user auth) ---
# Connector from dashboard: mcp.supabase.com/fuchsia-bridge
AETHOS_VERCEL_CONNECT_SUPABASE_ID=mcp.supabase.com/fuchsia-bridge
# Optional comma-separated scope override
# AETHOS_VERCEL_CONNECT_SCOPES=organizations:read,projects:read,database:write
# User-subject tokens only (never use placeholder usr_123):
# AETHOS_CONNECT_SUBJECT_USER_ID=
# From `vercel env pull` or CI:
# VERCEL_OIDC_TOKEN=
# VERCEL_TOKEN=
# Protects POST /api/ops/supabase-connect-token
# AETHOS_OPS_SECRET=

# Never expose Supabase service role keys, Connect access tokens, OpenAI API keys,
# database passwords, or Vercel tokens in client-side NEXT_PUBLIC_* variables.
