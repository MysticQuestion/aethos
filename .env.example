# Aethos can run without these values in local demo mode.
# Full setup: docs/SUPABASE_SETUP.md and docs/DEPLOYMENT.md

# --- Supabase (public only) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Calculation service (server-only) ---
# Recommended production: AETHOS_ALLOW_DEMO_FALLBACK=false
AETHOS_CALCULATION_SERVICE_URL=
AETHOS_ALLOW_DEMO_FALLBACK=true
AETHOS_CALC_PROVIDER=demo
# moshier = built-in (golden CI); files = licensed SE path required
AETHOS_SWISS_EPHEMERIS_MODE=moshier
AETHOS_SWISS_EPHEMERIS_PATH=
# Host path for docker compose volume (licensed ephemeris files)
AETHOS_SWISS_EPHEMERIS_HOST_PATH=./services/calculation/ephe

# Never expose Supabase service role keys, OpenAI API keys, database passwords,
# Vercel tokens, or private credentials in client-side variables.
